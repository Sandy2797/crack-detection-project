    "# ==============================\n",
    "# INFERENCE / IMAGE ANALYSIS SECTION\n",
    "# ==============================\n",
    "from tensorflow.keras.models import load_model\n",
    "\n",
    "model = load_model(\"models/transfer_model.h5\")\n",
    "\n",
    "model.compile(\n",
    "    optimizer=\"adam\",\n",
    "    loss=\"binary_crossentropy\",\n",
    "    metrics=[\"accuracy\"]\n",
    ")\n",
    "\n",
    "def imshow(img, title=\"Image\"):\n",
    "    plt.figure(figsize=(5, 5))\n",
    "\n",
    "    if len(img.shape) == 2:\n",
    "        plt.imshow(img, cmap=\"gray\")\n",
    "    else:\n",
    "        plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))\n",
    "\n",
    "    plt.title(title)\n",
    "    plt.axis(\"off\")\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "def preprocess_for_transfer(img):\n",
    "    img_resized = cv2.resize(img, (224, 224))\n",
    "    img_array = np.expand_dims(img_resized, axis=0)\n",
    "    img_array = preprocess_input(img_array)\n",
    "    return img_array\n",
    "\n",
    "\n",
    "def detect_cracks(img):\n",
    "    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
    "    blur = cv2.GaussianBlur(gray, (5, 5), 0)\n",
    "\n",
    "    edges_low = cv2.Canny(blur, 30, 100)\n",
    "    edges_high = cv2.Canny(blur, 100, 200)\n",
    "\n",
    "    edges = edges_low if np.sum(edges_low) > np.sum(edges_high) else edges_high\n",
    "\n",
    "    nLabels, labels, stats, _ = cv2.connectedComponentsWithStats(edges, connectivity=8)\n",
    "\n",
    "    output = img.copy()\n",
    "\n",
    "    for i in range(1, nLabels):\n",
    "        x, y, w, h, area = stats[i]\n",
    "\n",
    "        if area > 100:\n",
    "            cv2.rectangle(output, (x, y), (x + w, y + h), (0, 255, 0), 2)\n",
    "\n",
    "    return edges, output\n",
    "\n",
    "\n",
    "def analyze_crack_percentage(edges):\n",
    "    crack_pixels = cv2.countNonZero(edges)\n",
    "    total_pixels = edges.shape[0] * edges.shape[1]\n",
    "\n",
    "    percentage = (crack_pixels / total_pixels) * 100\n",
    "\n",
    "    if percentage < 1:\n",
    "        severity = \"Low\"\n",
    "    elif percentage < 5:\n",
    "        severity = \"Medium\"\n",
    "    else:\n",
    "        severity = \"High\"\n",
    "\n",
    "    return percentage, severity\n",
    "\n",
    "\n",
    "def analyze_image(img_path):\n",
    "    if not os.path.exists(img_path):\n",
    "        print(f\"Error: File not found -> {img_path}\")\n",
    "        return\n",
    "\n",
    "    img = cv2.imread(img_path)\n",
    "\n",
    "    if img is None:\n",
    "        print(f\"Error: Cannot read image -> {img_path}\")\n",
    "        return\n",
    "\n",
    "    input_img = preprocess_for_transfer(img)\n",
    "\n",
    "    prediction = model.predict(input_img)[0][0]\n",
    "\n",
    "    label = \"Crack Detected\" if prediction > 0.5 else \"No Crack\"\n",
    "\n",
    "    edges, detected = detect_cracks(img)\n",
    "\n",
    "    percentage, severity = analyze_crack_percentage(edges)\n",
    "\n",
    "    imshow(img, \"Original Image\")\n",
    "    imshow(edges, \"Edge Detection\")\n",
    "    imshow(detected, f\"{label} | Severity: {severity}\")\n",
    "\n",
    "    print(\"Prediction Score:\", round(float(prediction), 4))\n",
    "    print(\"Crack Area %:\", round(percentage, 2))\n",
    "    print(\"Severity:\", severity)\n",
    "    print(\"-\" * 40)\n",
    "\n",
    "\n",
    "test_images = [\n",
    "    \"data_split/test/Positive/00060.jpg\",\n",
    "    \"data_split/test/Negative/00010.jpg\"\n",
    "]\n",
    "\n",
    "for img_path in test_images:\n",
    "    analyze_image(img_path)"
